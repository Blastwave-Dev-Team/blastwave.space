# Copy to .env on the droplet and fill in values.
DB_PASSWORD=change-me-strong-password
WIKIJS_PORT=3000
BOOK_PROXY_PORT=3001
API_PORT=3002

# Wiki.js API key (Administration → API → Create new key)
WIKIJS_API_KEY=
WIKIJS_GRAPHQL_URL=http://wikijs:3000/graphql
WIKIJS_LOCALE=en
WIKIJS_TOC_POSITION=right
ASSET_CACHE_TTL_SECONDS=86400

# Content proxy
CACHE_TTL_SECONDS=300
BOOK_PROXY_HOST=0.0.0.0

# Site API (Express)
API_HOST=0.0.0.0
